include README.md
include ARTIFACT.md
include RELEASE_MANIFEST.md
include CITATION.cff
include LICENSE
include requirements-main.txt
include *.md
recursive-include tools *.py
recursive-include bug_repros *.py *.json *.md
recursive-include functions *.py
recursive-include inputs *.py
recursive-include run_tasks *.py
recursive-include tests *.py
recursive-include utilities *.py
exclude README.preartifact.tmp
global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude .pytest_cache/*
prune rank_0
prune results
prune dist
